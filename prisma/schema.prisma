datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model PortfolioConfig {
  id           Int      @id @default(1)
  artistName   String   @default("Dhruv Chaurasia")
  accentColor  String   @default("#D4AF37")
  passwordHash String   @default("c30d9c4c7c88b02c81fb3b9288e404b92b604e0e2ad0fb498b8433ad9fb1f71a")
  updatedAt    DateTime @updatedAt
}

model Artwork {
  id          Int      @id @default(autoincrement())
  title       String
  medium      String
  image       String
  year        String
  dimensions  String   @default("30 x 40 inches")
  location    String   @default("Artist Studio")
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
